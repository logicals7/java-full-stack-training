<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:p="http://www.springframework.org/schema/p"
	xmlns:c="http://www.springframework.org/schema/c"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

	<!--
		Add the below lines in beans tag
		xmlns:p="http://www.springframework.org/schema/p" -> for setter
		xmlns:c="http://www.springframework.org/schema/c" -> for constructor
	-->
	
	<!-- Inner Bean -->
	<bean id="emp1" class="com.spring.learn.EmployeeBean">
		<property name="empId" value="101"/>
    	<property name="empName" value="Nands"/>
    	<property name="role" value="Devops"/>
    	<property name="salary" value="450000"/>
    	<!--InnerBean: Bean Inside Bean-->
    	<!--InnerBean: Id is optional. picks up from parent bean-->
		<property name="address"> 
			<bean class="com.spring.learn.AddressBean">
				<property name="area" value="Lohad Bazaar"/>
				<property name="city" value="Bhiwani"/>
			</bean>
		</property>
	</bean>
	
	
	<!-- Ref Bean -->
	<bean id="emp2" class="com.spring.learn.EmployeeBean">
		<property name="empId" value="102"/>
    	<property name="empName" value="Krishan"/>
    	<property name="role" value="Developer"/>
    	<property name="salary" value="450000"/>
    	<!--Ref: Bean Outside Bean-->
    	<!--Ref: Id is optional. picks up from parent bean-->
		<property name="address" ref="add"/>
	</bean>
	
	<bean id="add" class="com.spring.learn.AddressBean">
		<property name="area" value="Bada Bazaar"/>
		<property name="city" value="Kanina"/>
	</bean>
	
</beans>
	