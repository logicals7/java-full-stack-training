<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- Scope : observe the output
    	 - Singleton: Will allow to create only one object
  		- prototype: Will allow to create multiple object 
    -->
    
    <bean id="emp1" class="com.spring.learn.EmployeeBean" scope="singleton">
    	<property name="empId" value="101"/>
    	<property name="empName" value="Mark"/>
    	<property name="role" value="Developer"/>
    	<property name="salary" value="45000"/>
    </bean>
    
    <bean id="emp2" class="com.spring.learn.EmployeeBean" scope="prototype">
    	<property name="empId" value="102"/>
    	<property name="empName" value="Clark"/>
    	<property name="role" value="DevOps"/>
    	<property name="salary" value="55000"/>
    </bean>
    
</beans>