<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:p="http://www.springframework.org/schema/p"
	xmlns:c="http://www.springframework.org/schema/c"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

	
	<!-- autowire by type -->
	<!-- bean id of injectable bean is optional -->
	<bean id="emp1" class="com.spring.learn.EmployeeBean" autowire="byType">
		<property name="empId" value="101"/>
    	<property name="empName" value="Kirti"/>
    	<property name="role" value="Devops"/>
    	<property name="salary" value="450000"/>
	</bean>
	
	<!-- bean id of injectable bean is optional. You can give any id name like id="add1". it doesn't matter.-->
	<bean id="add2" class="com.spring.learn.AddressBean">
		<property name="area" value="Bada Bazaar"/>
		<property name="city" value="Kanina"/>
	</bean>
	
	<!--If there are more than one bean of same type, then primary bean should be injected.-->
	<!--If there are more than one bean of same type, and none of the bean has same id as address field in main bean.-->
	<!--the exception is thrown here.-->
	<bean id="add2" class="com.spring.learn.AddressBean" primary="true">
		<property name="area" value="Lohad Bazaar"/>
		<property name="city" value="Bhiwani"/>
	</bean>
	
	<!-- Points:
		- If we have zero bean for reference class-> Will get null values
		  - If we have One bean for reference class-> Will get values
		  - If we have more than one bean for reference class-> Will get exception -> NoUniqueBeanDefinitionException
		  - how to resolve that ambiguity if more than one bean
		    	-> we can use primary attribute to make one of the bean as primary

	-->
	
</beans>
	